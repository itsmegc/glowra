# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
# Use the "pooled" connection string for DATABASE_URL (required for serverless)
DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
# Use the "direct" (unpooled) connection for Prisma migrations
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
# In dev: http://localhost:3000 | In prod: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Magic Link) ────────────────────────────────────────────────────────
# Option 1: Gmail (enable App Passwords in Google Account settings)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="you@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="Glowra <you@gmail.com>"

# Option 2: Resend (https://resend.com) — recommended for production
# EMAIL_SERVER_HOST="smtp.resend.com"
# EMAIL_SERVER_PORT="465"
# EMAIL_SERVER_USER="resend"
# EMAIL_SERVER_PASSWORD="re_your_api_key"
# EMAIL_FROM="Glowra <hello@glowra.app>"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Cloudinary (Phase 2 — image uploads) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
